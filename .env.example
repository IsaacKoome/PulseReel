# PulseReel local model backend setup
#
# Copy this file to `.env.local` and fill in the values you actually have.
# If none of the model-backend vars are set, PulseReel will keep using the
# current built-in external runner fallback.

# Optional: path to your preferred Python executable.
# Example:
# PULSEREEL_PYTHON_EXECUTABLE=C:\Users\Isaac\AppData\Local\Programs\Python\Python311\python.exe
PULSEREEL_PYTHON_EXECUTABLE=

# Optional: override ffmpeg path if needed.
# Example:
# PULSEREEL_FFMPEG=C:\Users\Isaac\Documents\New project\node_modules\ffmpeg-static\ffmpeg.exe
PULSEREEL_FFMPEG=

# Optional: completely custom backend command.
# Available placeholders:
#   {payload} -> absolute path to payload.json
#   {result}  -> absolute path to result.json
#   {status}  -> absolute path to status.json
# Example:
# PULSEREEL_MODEL_BACKEND_COMMAND="C:\tools\my-backend.bat" "{payload}" "{result}" "{status}"
PULSEREEL_MODEL_BACKEND_COMMAND=

# Optional: choose the heavy provider explicitly.
# Valid values: open-model-adapter, local-heavy-v1
PULSEREEL_HEAVY_PROVIDER=open-model-adapter

# ComfyUI integration
# If these are set, the Python bridge will automatically try ComfyUI before
# falling back to the local Python runner.
#
# Example:
# PULSEREEL_COMFYUI_URL=http://127.0.0.1:8188
PULSEREEL_COMFYUI_URL=
#
# Example:
# PULSEREEL_COMFYUI_WORKFLOW_TEMPLATE=C:\Users\Isaac\Documents\New project\data\comfyui\portrait-img2img-workflow.json
PULSEREEL_COMFYUI_WORKFLOW_TEMPLATE=

# Optional: explicit checkpoint filename or absolute path.
# If omitted, PulseReel will auto-pick the first valid model file found in
# tools\ComfyUI\models\checkpoints.
# Example:
# PULSEREEL_COMFYUI_CHECKPOINT=juggernautXL.safetensors
PULSEREEL_COMFYUI_CHECKPOINT=

# Optional: advanced IPAdapter workflow support.
# If omitted, PulseReel will try to auto-pick from the matching ComfyUI model folders.
# Examples:
# PULSEREEL_COMFYUI_IPADAPTER_MODEL=ip-adapter-plus-face_sdxl_vit-h.bin
# PULSEREEL_COMFYUI_CLIP_VISION_MODEL=clip_vision_g.safetensors
PULSEREEL_COMFYUI_IPADAPTER_MODEL=
PULSEREEL_COMFYUI_CLIP_VISION_MODEL=

# Optional: stable client id for ComfyUI queue requests.
PULSEREEL_COMFYUI_CLIENT_ID=

# Optional: default negative prompt for the ComfyUI backend.
PULSEREEL_COMFYUI_NEGATIVE_PROMPT=blurry, distorted, low quality, malformed anatomy
